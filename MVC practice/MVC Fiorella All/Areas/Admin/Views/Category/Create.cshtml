@model Category

<main>

    <div class="container" style="margin-right:100px">

        <form asp-action="Create" method="post">

            <div class="mb-3">

                <label class="form-label">
                    Category Name
                </label>

                <input asp-for="Name"
                       class="form-control">

            </div>

            <button type="submit"
                    class="btn btn-success">

                Create

            </button>

            <a asp-action="Index"
                   class="btn btn-secondary">

                Go Back

            </a>

        </form>

    </div>

</main>