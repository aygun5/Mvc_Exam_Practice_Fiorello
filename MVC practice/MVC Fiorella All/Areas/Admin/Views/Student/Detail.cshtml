@model MVC_Fiorella_All.ViewModels.Student.StudentDetailVM

@{
    ViewData["Title"] = "Student Detail";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="student-wrapper">

    <div class="top-bar">
        <h2>Student Detail</h2>

        <a asp-action="Index" class="back-btn">
            Back
        </a>
    </div>

    <div class="student-card">

        <div class="item">
            <span>Name</span>
            <p>@Model.Name</p>
        </div>

        <div class="item">
            <span>Surname</span>
            <p>@Model.Surname</p>
        </div>

        <div class="item">
            <span>Age</span>
            <p>@Model.Age</p>
        </div>

        <div class="item">
            <span>Group</span>
            <p>@Model.Group</p>
        </div>

        <div class="item">
            <span>Grade</span>
            <p>@Model.Grade</p>
        </div>

        <div class="item">
            <span>Faculty</span>
            <p>@Model.Faculty</p>
        </div>

        <div class="item">
            <span>Phone</span>
            <p>@Model.Phone</p>
        </div>

        <div class="item">
            <span>Email</span>
            <p>@Model.Email</p>
        </div>

        <div class="item">
            <span>Address</span>
            <p>@Model.Adress</p>
        </div>

    </div>

</div>

<style>

    .student-wrapper {
        width: 75%;
        margin-top: 30px;
        margin-left: 240px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

        .top-bar h2 {
            color: white;
            font-size: 28px;
            font-weight: bold;
        }

    .back-btn {
        background: white;
        color: black;
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
    }

        .back-btn:hover {
            background: #e9ecef;
        }

    .student-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .item {
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 1px solid #ddd;
    }

        .item:last-child {
            border-bottom: none;
        }

        .item span {
            display: block;
            font-size: 13px;
            color: gray;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .item p {
            margin: 0;
            font-size: 20px;
            font-weight: bold;
            color: #212529;
        }

</style>