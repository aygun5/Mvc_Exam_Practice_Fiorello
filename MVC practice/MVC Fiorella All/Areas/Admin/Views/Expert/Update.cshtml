@model ExpertUpdateVM

@{
    ViewData["Title"] = "Update";
}

<main>
    <div class="container" style="margin-right:100px">

        <form asp-action="Update" method="post" enctype="multipart/form-data">
            <img src="~/assets/img/@Model.Image" height="100px" width="100px" alt="Expert Image">
            <div class="mb-3">
                <label class="form-label"> Enter FullName </label>
                <input asp-for="FullName" class="form-control" type="text" accept="image/*">
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Enter Job</label>
                <input asp-for="Job" class="form-control" type="text" accept="image/*">
                <span asp-validation-for="Job" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Choose Image</label>
                <input asp-for="NewImage" class="form-control" type="file" accept="image/*">
                <span asp-validation-for="NewImage" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Update</button>
            <a asp-action="Index" class="btn btn-light">Cancel</a>
        </form>
    </div>
</main>

