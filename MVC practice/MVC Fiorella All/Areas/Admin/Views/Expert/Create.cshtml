@model ExpertCreateVM
@{
    ViewData["Title"] = "Create";
}

<main>
    <div class="container" style="margin-right:100px">

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label"> Enter FullName </label>
                <input asp-for="FullName" class="form-control" type="text" accept="image/*">
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Enter Job</label>
                <input asp-for="Job" class="form-control" type="text" accept="image/*">
                <span asp-validation-for="Job" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label"> Choose Image </label>
                <input asp-for="Image" class="form-control" type="file" accept="image/*">
                <span asp-validation-for="Image" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Create</button>
            <a asp-action="Index" class="btn btn-light">Cancel</a>
        </form>
    </div>
</main>
