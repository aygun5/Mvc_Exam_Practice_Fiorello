@model Blog
@using MVC_Fiorella_All.Models

@{
    ViewData["Title"] = "Blog Detail";
}

<main>
    <section class="blog-detail py-5">
        <div class="container">

            <div class="row justify-content-center">
                <div class="col-lg-10">

                    <div class="row">
                        @foreach (var image in Model.BlogImages)
                        {
                            <div class="col-md-4 mb-3">
                                <img src="~/assets/img/@image.Image"
                                     class="img-fluid rounded shadow"
                                     style="width:100%; height:250px; object-fit:cover;" />
                            </div>
                        }
                    </div>

                    <div class="blog-content text-center">

                        <p class="text-muted mb-3" style="font-size:18px;">
                            @Model.CreatedDate.ToString("MMMM dd, yyyy")
                        </p>

                        <h1 class="fw-bold mb-4" style="font-size:45px;">
                            @Model.Title
                        </h1>

                        <div class="blog-description mt-4">
                            <p style="font-size:20px; line-height:38px; color:#555;">
                                @Model.Description
                            </p>
                        </div>

                        <div class="mt-5">
                            <a asp-controller="Blog"
                                   asp-action="Index"
                                   class="btn btn-dark px-4 py-2">
                                Back To Blogs
                            </a>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </section>
</main>